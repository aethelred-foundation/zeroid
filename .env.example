# ═══════════════════════════════════════════════════════════════
# ZeroID — Self-Sovereign Identity dApp
# ═══════════════════════════════════════════════════════════════

# ── Network Configuration ──────────────────────────────────────
NEXT_PUBLIC_CHAIN_ENV=testnet
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.aethelred.io
NEXT_PUBLIC_WS_URL=wss://ws.testnet.aethelred.io
NEXT_PUBLIC_EXPLORER_URL=https://explorer.testnet.aethelred.io

# ── Contract Addresses ────────────────────────────────────────
NEXT_PUBLIC_ZEROID_ADDRESS=0x...
NEXT_PUBLIC_CREDENTIAL_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_ZK_VERIFIER_ADDRESS=0x...
NEXT_PUBLIC_TEE_REGISTRY_ADDRESS=0x...
NEXT_PUBLIC_SELECTIVE_DISCLOSURE_ADDRESS=0x...
NEXT_PUBLIC_GOVERNANCE_ADDRESS=0x...

# ── API Configuration ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4003
NEXT_PUBLIC_TEE_ENDPOINT=https://tee.testnet.aethelred.io
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.aethelred.io

# ── ZK Circuits ───────────────────────────────────────────────
NEXT_PUBLIC_CIRCUITS_BASE_URL=/circuits
NEXT_PUBLIC_AGE_PROOF_WASM=/circuits/age/age_proof.wasm
NEXT_PUBLIC_AGE_PROOF_ZKEY=/circuits/age/age_proof_final.zkey
NEXT_PUBLIC_RESIDENCY_PROOF_WASM=/circuits/residency/residency_proof.wasm
NEXT_PUBLIC_RESIDENCY_PROOF_ZKEY=/circuits/residency/residency_proof_final.zkey
NEXT_PUBLIC_CREDIT_PROOF_WASM=/circuits/credit/credit_tier_proof.wasm
NEXT_PUBLIC_CREDIT_PROOF_ZKEY=/circuits/credit/credit_tier_proof_final.zkey

# ── WalletConnect ─────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# ── Backend ───────────────────────────────────────────────────
DATABASE_URL=postgresql://zeroid:zeroid@localhost:5432/zeroid
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRY=24h
KMS_PROVIDER=aws-kms
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/replace-me
KMS_KEY_VERSION=1
CREDENTIAL_SIGNING_PRIVATE_KEY=base64-pkcs8-or-pem-private-key
CREDENTIAL_SIGNING_PUBLIC_KEY=base64-spki-or-pem-public-key
CREDENTIAL_SIGNING_PUBLIC_KEYS_JSON={"1":"base64-spki-or-pem-public-key"}
CREDENTIAL_SIGNING_VERIFICATION_METHOD=did:aethelred:zeroid:credential-signer#key-1
ALLOW_LOCAL_CREDENTIAL_SIGNING=false
ALLOW_LEGACY_HMAC_CREDENTIAL_SIGNING=false

# ── Production Safety Gates ──────────────────────────────────
# CRITICAL: All of these MUST be false in production. Setting any to true
# bypasses security controls and is logged as a CRITICAL_SECURITY_VIOLATION.
# Signing keys MUST be stored in KMS/HSM — never in env files for production.
# ALLOW_LOCAL_CREDENTIAL_SIGNING=false    # Use KMS_PROVIDER=aws-kms instead
# ALLOW_LEGACY_HMAC_CREDENTIAL_SIGNING=false  # HMAC signing is deprecated
# ALLOW_PUBLIC_OIDC_CLIENTS=false         # All OIDC clients must use client_secret
# ALLOW_UNSAFE_TEE_ATTESTATION=false      # Always verify real DCAP quotes

# ── TEE Configuration ────────────────────────────────────────
TEE_ENCLAVE_KEY=...
TEE_ATTESTATION_PROVIDER=intel-sgx
TEE_DCAP_API_URL=https://api.trustedservices.intel.com/sgx/certification/v4
INTEL_PCS_API_KEY=your_intel_pcs_api_key
TEE_ALLOWED_TCB_STATUSES=UpToDate
TRUSTED_MRSIGNERS=comma-separated-hex-mrsigner-values
ALLOW_UNSAFE_TEE_ATTESTATION=false

# ── Government API Integration ────────────────────────────────
UAE_PASS_CLIENT_ID=your_uae_pass_client_id
UAE_PASS_CLIENT_SECRET=your_uae_pass_client_secret
UAE_PASS_API_URL=https://api.uaepass.ae
UAE_PASS_REDIRECT_URI=https://zeroid.aethelred.io/callback/uaepass
EMIRATES_ID_VERIFICATION_URL=https://verify.emiratesid.ae/api

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=info
METRICS_PORT=9090

# ── Session & Security ───────────────────────────────────────
ZEROID_SESSION_SECRET=your-session-secret
ZEROID_ALLOWED_ORIGINS=http://localhost:3003,https://zeroid.aethelred.io
ZEROID_ENABLE_HSTS=true
ZEROID_RATE_LIMIT_WINDOW_MS=60000
ZEROID_RATE_LIMIT_MAX=100

# ═══════════════════════════════════════════════════════════════
# ENTERPRISE EXPANSION
# ═══════════════════════════════════════════════════════════════

# ── AI Compliance Engine ──────────────────────────────────────
AI_RISK_MODEL_VERSION=v1.0
AI_FRAUD_DETECTION_THRESHOLD=0.7
AI_BEHAVIORAL_BASELINE_DAYS=30
AI_COPILOT_MODEL=claude-sonnet-4-6
AI_COPILOT_API_KEY=your_anthropic_api_key

# ── Sanctions & PEP Screening ────────────────────────────────
OFAC_SDN_API_URL=https://sanctionssearch.ofac.treas.gov/api
EU_SANCTIONS_API_URL=https://webgate.ec.europa.eu/fsd/fsf/api
UN_SANCTIONS_API_URL=https://scsanctions.un.org/api
UAE_SANCTIONS_LIST_URL=https://sanctions.cbuae.gov.ae/api
PEP_DATABASE_URL=https://pep.aethelred.io/api
SCREENING_FUZZY_MATCH_THRESHOLD=0.85

# ── Regulatory Compliance ────────────────────────────────────
SUPPORTED_JURISDICTIONS=UAE,EU,US,SG,UK,BH,SA,HK,JP
DEFAULT_DATA_RETENTION_YEARS=7
GDPR_DPO_EMAIL=dpo@aethelred.io
REGULATORY_REPORTING_API_URL=https://regulatory.aethelred.io/api

# ── Enterprise Integration ───────────────────────────────────
OIDC_ISSUER_URL=https://zeroid.aethelred.io/enterprise/oidc
OIDC_SIGNING_ALG=RS256
OIDC_SIGNING_PRIVATE_KEY=base64-pkcs8-or-pem-private-key
OIDC_SIGNING_PUBLIC_KEY=base64-spki-or-pem-public-key
OIDC_SIGNING_KEY_ID=zeroid-oidc-key-1
ALLOW_PUBLIC_OIDC_CLIENTS=false
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_BACKOFF_BASE_MS=1000
API_GATEWAY_RATE_LIMIT_DEFAULT=60
ENTERPRISE_BILLING_API_URL=https://billing.aethelred.io/api

# ── Cross-Chain Bridge ───────────────────────────────────────
NEXT_PUBLIC_BRIDGE_CONTRACT_ADDRESS=0x...
BRIDGE_RELAYER_KEY=your_relayer_private_key
BRIDGE_ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/your_key
BRIDGE_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your_key
BRIDGE_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/your_key
BRIDGE_FRAUD_PROOF_WINDOW_HOURS=24

# ── AI Agent Identity ────────────────────────────────────────
AGENT_MAX_DELEGATION_DEPTH=5
AGENT_DEFAULT_RATE_LIMIT=60
AGENT_APPROVAL_TIMEOUT_HOURS=24
AGENT_REPUTATION_DECAY_RATE=0.01

# ── Marketplace ──────────────────────────────────────────────
MARKETPLACE_MIN_ISSUER_TRUST_SCORE=60
MARKETPLACE_LISTING_FEE_AETH=10
MARKETPLACE_STAKING_MIN_AETH=100
